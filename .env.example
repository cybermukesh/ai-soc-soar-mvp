# Backend
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
JWT_SECRET=replace-with-strong-secret

# Wazuh / OpenSearch
WAZUH_API_URL=https://wazuh.example.com:55000
WAZUH_API_USER=
WAZUH_API_PASSWORD=
OPENSEARCH_URL=https://wazuh.example.com:9200
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=
OPENSEARCH_ALERT_INDEX=wazuh-alerts-*

# LLM
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_MAX_INPUT_CHARS=6000
LLM_MAX_OUTPUT_TOKENS=700
LLM_CACHE_ENABLED=true
LLM_TRIAGE_ONLY_MIN_SEVERITY=medium
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# SOAR
N8N_WEBHOOK_URL=
SHUFFLE_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
